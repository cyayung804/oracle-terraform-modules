module "oke_operator" {
  source                         = "oracle-terraform-modules/oke/oci//modules/operator"
  version                        = "5.4.3"
  compartment_id                 = var.compartment_id
  bastion_host                   = var.bastion_host
  await_cloudinit                = var.await_cloudinit
  kubernetes_version             = var.kubernetes_version
  operator_image_os_version      = var.operator_image_os_version
  tag_namespace                  = var.tag_namespace
  use_defined_tags               = var.use_defined_tags
  pv_transit_encryption          = var.pv_transit_encryption
  subnet_id                      = var.subnet_id
  user                           = var.user
  image_id                       = var.image_id
  install_oci_cli_from_repo      = var.install_oci_cli_from_repo
  install_helm_from_repo         = var.install_helm_from_repo
  install_istioctl               = var.install_istioctl
  install_kubectl_from_repo      = var.install_kubectl_from_repo
  shape                          = var.shape
  legacy_imds_endpoints_disabled = var.legacy_imds_endpoints_disabled
  assign_dns                     = var.assign_dns
  availability_domain            = var.availability_domain
  install_cilium                 = var.install_cilium
  install_k8sgpt                 = var.install_k8sgpt
  ssh_private_key                = var.ssh_private_key
  volume_kms_key_id              = var.volume_kms_key_id
  bastion_user                   = var.bastion_user
  install_kubectx                = var.install_kubectx
  install_stern                  = var.install_stern
  nsg_ids                        = var.nsg_ids
  ssh_public_key                 = var.ssh_public_key
  cloud_init                     = var.cloud_init
  install_helm                   = var.install_helm
  install_k9s                    = var.install_k9s
  kubeconfig                     = var.kubeconfig
  defined_tags                   = var.defined_tags
  state_id                       = var.state_id
  timezone                       = var.timezone
  upgrade                        = var.upgrade
  freeform_tags                  = var.freeform_tags
}
